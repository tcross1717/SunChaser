# Copy this file to .env and fill in your values.

# SerpAPI — real Google Flights + Hotels data (serpapi.com, free tier: 100 searches/month)
SERPAPI_API_KEY=your_serpapi_api_key

# seats.aero Partner API — real award availability (seats.aero/partner-api)
SEATS_AERO_API_KEY=your_seats_aero_api_key

# Telegram Bot (create via @BotFather, get chat_id via @userinfobot)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# Database (defaults to local SQLite — change to postgres:// for production)
DATABASE_URL=sqlite:///sunchaser.db

# Dashboard — where the FastAPI backend is running
SUNCHASER_API=http://localhost:8000/api
